# ============================================================
# Johnson's Barbers — environment variables
# Copy this file to `.env.local` and fill in the values.
# NEVER commit .env.local (it's gitignored).
# ============================================================

# --- Supabase (Project Settings → API) ---
# Public: safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Secret: server-only. Bypasses row-level security for admin/booking writes.
# Get from Project Settings → API → service_role. Keep it secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Resend (email alerts + confirmations) ---
# https://resend.com → API Keys
RESEND_API_KEY=re_your_api_key
# The "from" address. Must be a domain you've verified in Resend,
# e.g. "Johnson's Barbers <bookings@yourdomain.com>".
# For quick testing you can use "onboarding@resend.dev".
EMAIL_FROM=onboarding@resend.dev
# Fallback inbox for the shop (used if a barber has no email set).
SHOP_EMAIL=owner@example.com

# --- Cron security (Vercel Cron → protects the reminder endpoint) ---
CRON_SECRET=make-up-a-long-random-string

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
